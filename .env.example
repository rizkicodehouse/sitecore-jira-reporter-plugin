# ──────────────────────────────────────────────────────────
# Bug Reporter for Jira — environment variables
#
# All tenant-specific config (Jira creds, project key,
# admins) is managed per-tenant through the plugin's
# Settings UI. The vars below are vendor-level (set once
# by whoever operates the plugin deployment).
# ──────────────────────────────────────────────────────────

# Required in production (next.config hard-fails without it).
# Sitecore host origins — space-separated list. All entries
# populate CSP `frame-ancestors`. The first entry is used for
# the CORS `Access-Control-Allow-Origin` header.
# - `pages.sitecorecloud.io` hosts the Pages Context Panel.
# - `app.sitecorecloud.io` hosts the Full Screen extension
#   (XMC Portfolio top-bar navigation).
ALLOWED_PLUGIN_ORIGIN=https://pages.sitecorecloud.io https://app.sitecorecloud.io

# Recommended. Base64 of 32 random bytes — encrypts JIRA
# API tokens at rest. If omitted:
#   - dev: auto-generates an ephemeral key (lost on restart)
#   - prod: bootstraps a key into Redis and warns
# Generate with:
#   node -e "console.log(require('crypto')\
#     .randomBytes(32).toString('base64'))"
SETTINGS_ENCRYPTION_KEY=

# Required for multi-tenant persistence. Without it the
# plugin uses an in-memory settings store that resets on
# every server restart (fine for local dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional super-admin list (comma-separated). These
# emails can edit settings on any tenant regardless of
# the tenant's admin allowlist. Leave blank to rely only
# on per-tenant admins.
PLUGIN_ADMIN_EMAILS=

# Optional dev fallbacks. If a tenant hasn't configured
# JIRA through the Settings UI yet, these are used so
# dev-against-real-tenant workflows still work.
JIRA_BASE_URL=
JIRA_SERVICE_EMAIL=
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT_KEY=
JIRA_DEFAULT_ISSUE_TYPE=Bug

# Attachment size cap (MB). Defaults to 25 if unset.
MAX_ATTACHMENT_MB=25

# ──────────────────────────────────────────────────────────
# Auth0 — session auth for all /api/** and iframe routes.
# See docs/auth0-cloud-portal-setup.md for the Cloud Portal
# registration flow that produces the client credentials.
# All seven variables are required in every environment;
# the Auth0Client constructor throws at startup without
# them.
# ──────────────────────────────────────────────────────────

# 32 random bytes, base64. Signs the session cookie.
# Generate with:
#   node -e "console.log(require('crypto')\
#     .randomBytes(32).toString('base64'))"
AUTH0_SECRET=

# Fixed for the Sitecore Auth0 tenant.
AUTH0_DOMAIN=https://auth.sitecorecloud.io

# From the Cloud Portal "Create credentials for regular
# web app" dialog. Per-plugin, per-environment if you
# register separate credentials for Production / Preview.
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Fixed for the Sitecore Marketplace resource server.
AUTH0_AUDIENCE=https://api-webapp.sitecorecloud.io
AUTH0_SCOPE=openid profile email offline_access

# Public base URL of this deployment. Used by Auth0 to
# build the callback URL (/api/auth/callback). Must be
# HTTPS except for http://localhost:3002 in dev.
APP_BASE_URL=https://sitecore-jira-reporter-plugin.vercel.app
